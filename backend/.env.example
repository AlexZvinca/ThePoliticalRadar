# Azure AI Language resource values.
# Example endpoint shape: https://your-resource-name.cognitiveservices.azure.com/
AZURE_LANGUAGE_ENDPOINT=
AZURE_LANGUAGE_KEY=

# Optional live source API key.
YOUTUBE_API_KEY=

# Optional future persistent storage.
DATABASE_URL=

# HTTP timeout for Azure/data-source requests.
REQUEST_TIMEOUT_SECONDS=12
HTTP_USER_AGENT=ThePoliticalRadar/0.1 (academic cloud AI course project)

# Wikimedia asks for an identifying User-Agent with contact information.
# Replace with your real email or project contact before enabling Wikipedia profile lookup.
WIKIMEDIA_USER_AGENT=ThePoliticalRadar/0.1 (student project; contact: your.email@example.com)

# Comma-separated frontend URLs allowed to call the API.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
